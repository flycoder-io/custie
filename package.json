{
  "name": "custie",
  "version": "1.0.20",
  "description": "Claude Code, inside your Slack",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "custie": "dist/cli.js"
  },
  "files": [
    "dist",
    "system.default.md",
    "system.capabilities.md",
    "slack-app-manifest.yml"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts start",
    "dev:debug": "DEBUG=true tsx src/cli.ts start",
    "build": "tsup",
    "start": "node dist/cli.js start",
    "reload": "pnpm run build && launchctl kickstart -k \"gui/$(id -u)/io.flycoder.custie\"",
    "lint": "oxlint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm version patch && npm publish && git push --follow-tags"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@slack/bolt": "^4.6.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.4",
    "js-yaml": "^4.1.1",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.2.3",
    "oxlint": "^1.46.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a"
}
